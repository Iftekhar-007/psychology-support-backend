{
  "compilerOptions": {
    // "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "bundler",
     "target": "ES2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules","dist"]
}

